#!/bin/sh
echo "Content-Type: text/plain; charset=utf-8"
echo ""

CONFIG_DIR="${CONFIG_DIR:-/root/.config/mihomo}"

if [ "$REQUEST_METHOD" != "POST" ]; then
  echo "Error: POST required"
  exit 1
fi

body=$(dd bs=1 count="$CONTENT_LENGTH" 2>/dev/null)

urldecode() {
  printf '%s\n' "$1" | sed 's/+/ /g; s/%\([0-9A-Fa-f][0-9A-Fa-f]\)/\\\x\1/g' | while IFS= read -r line; do printf '%b' "$line"; done
}

extract_field() {
  printf '%s' "$body" | awk -F'&' -v key="$1" '{
    for(i=1;i<=NF;i++) {
      n=length(key)+1
      if (substr($i,1,n) == key"=") { print substr($i,n+1); exit }
    }
  }'
}

file=$(urldecode "$(extract_field file)")
b64=$(urldecode "$(extract_field b64)")
type=$(extract_field type)
[ -z "$type" ] && type="ruleset"

case "$type" in
  ruleset) TARGET_DIR="$CONFIG_DIR/rule_set_list" ;;
  proxy)   TARGET_DIR="$CONFIG_DIR/proxies_mount" ;;
  awg)     TARGET_DIR="$CONFIG_DIR/awg" ;;
  fakebin) TARGET_DIR="/zapret-fakebin" ;;
  zlist)   TARGET_DIR="/zapret-lists" ;;
  *) echo "Error: invalid type"; exit 1 ;;
esac

base=$(basename "$file")
if [ "$base" != "$file" ] || [ -z "$base" ]; then
  echo "Error: invalid filename"
  exit 1
fi

case "$base" in
  .*) echo "Error: hidden files not allowed"; exit 1 ;;
esac

mkdir -p "$TARGET_DIR" 2>/dev/null
target="$TARGET_DIR/$base"

if [ -n "$b64" ]; then
  printf '%s' "$b64" | base64 -d > "$target" 2>/dev/null
else
  : > "$target"
fi

if [ $? -eq 0 ]; then
  echo "OK"
else
  echo "Error: write failed"
fi

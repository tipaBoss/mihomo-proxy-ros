FROM --platform=$BUILDPLATFORM alpine:latest AS package
ARG TARGETOS
ARG TARGETARCH
ARG TARGETVARIANT
ARG AMD64VERSION
ARG TAG
ARG WITH_GVISOR=1
ARG BUILDTIME
RUN apk add --no-cache curl jq gzip tar unzip git make python3 go

RUN mkdir -p /final 

# Клонируем репозиторий
RUN git clone https://github.com/MetaCubeX/mihomo.git /src
WORKDIR /src

# Переключаемся на нужный тэг
RUN git fetch --all --tags --prune && git switch --detach "$TAG" 2>/dev/null || git switch "$TAG"

# Патч vision panic (slice bounds out of range в filter.go)
RUN python3 - <<'PY'
from pathlib import Path
import re

p = Path("transport/vless/vision/filter.go")
s = p.read_text(encoding="utf-8")

# already patched -> skip
if "cipherPos := index + 43 + sessionIDLen + 1" in s and "if i > lenP {" in s:
    print("vision filter already patched")
    raise SystemExit(0)

# patch 1: safe cipher slice bounds
pat1 = re.compile(
    r'(\s*sessionIDLen := int\(buffer\[index\+43\]\)\n)\s*vc\.cipher = binary\.BigEndian\.Uint16\(buffer\[index\+43\+sessionIDLen\+1:\]\)'
)
rep1 = (
    r'\1'
    r'\t\t\t\t\t\tcipherPos := index + 43 + sessionIDLen + 1\n'
    r'\t\t\t\t\t\tif cipherPos+2 <= lenP {\n'
    r'\t\t\t\t\t\t\tvc.cipher = binary.BigEndian.Uint16(buffer[cipherPos:])\n'
    r'\t\t\t\t\t\t}'
)
s, n1 = pat1.subn(rep1, s, count=1)

# patch 2: clamp i and safe decrement
pat2 = re.compile(
    r'(\s*if i < 0 {\n\s*i = 0\n\s*}\n)\s*if i\+end > lenP {\n\s*end = lenP\n\s*vc\.remainingServerHello -= uint16\(end - i\)\n\s*} else {'
)
rep2 = (
    r'\1'
    r'\t\tif i > lenP {\n'
    r'\t\t\ti = lenP\n'
    r'\t\t}\n'
    r'\t\tif i+end > lenP {\n'
    r'\t\t\tend = lenP\n'
    r'\t\t\tif end > i {\n'
    r'\t\t\t\tvc.remainingServerHello -= uint16(end - i)\n'
    r'\t\t\t}\n'
    r'\t\t} else {'
)
s, n2 = pat2.subn(rep2, s, count=1)

if n1 != 1 or n2 != 1:
    raise SystemExit(f"patch failed: n1={n1}, n2={n2}")

p.write_text(s, encoding="utf-8")
print("Applied vision filter bounds patch")
PY

RUN echo "Patching version/updater for fork TAG=${TAG} BUILDTIME=${BUILDTIME}" && \
    sed -i "s|Version\\s*=.*|Version = \"${TAG}-mihomo-proxy-ros\"|" constant/version.go && \
    sed -i "s|BuildTime\\s*=.*|BuildTime = \"${BUILDTIME}\"|" constant/version.go && \
    sed -i 's|MihomoName = "mihomo"|MihomoName = "mihomo-proxy-ros"|' constant/version.go && \
    sed -i 's|baseReleaseURL    = "https://github.com/MetaCubeX/mihomo/releases/latest/download/"|baseReleaseURL    = "https://github.com/Medium1992/mihomo-proxy-ros/releases/latest/download/"|' component/updater/update_core.go && \
    sed -i 's|versionReleaseURL = "https://github.com/MetaCubeX/mihomo/releases/latest/download/version.txt"|versionReleaseURL = "https://github.com/Medium1992/mihomo-proxy-ros/releases/latest/download/version.txt"|' component/updater/update_core.go && \
    sed -i 's|if latestVersion == C.Version && !force {|if strings.TrimSuffix(C.Version, "-mihomo-proxy-ros") == latestVersion \&\& !force {|' component/updater/update_core.go

RUN sed -i '/^import (/a\    "github.com/metacubex/mihomo/log"' \
    adapter/provider/provider.go

RUN sed -i 's@return nil, fmt.Errorf("proxy %d error: %w", idx, err)@name, _ := mapping["name"].(string)\n                log.Warnln("[Provider %s] skip invalid proxy (idx=%d, name=%q): %v", pdName, idx, name, err)\n                continue@g' \
    adapter/provider/provider.go
  
# Формируем список build tags и собираем
RUN BUILD_TAGS="" && \
    if [ "$WITH_GVISOR" = "1" ]; then BUILD_TAGS="with_gvisor"; fi && \
    echo "Building with tags: $BUILD_TAGS" && \
    if [ "$TARGETARCH" = "amd64" ]; then \
        echo "Setting GOAMD64=$AMD64VERSION for amd64"; \
        CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH GOAMD64=$AMD64VERSION \
        go build -tags "$BUILD_TAGS" -trimpath -ldflags "-w -s -buildid=" -o /final/mihomo .; \
    elif [ "$TARGETARCH" = "arm" ]; then \
        if [ "$TARGETVARIANT" = "v5" ]; then \
            echo "Building for ARMv5 (GOARM=5)"; \
            CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=arm GOARM=5 \
            go build -tags "$BUILD_TAGS" -trimpath -ldflags "-w -s -buildid=" -o /final/mihomo .; \
        elif [ "$TARGETVARIANT" = "v7" ]; then \
            echo "Building for ARMv7 (GOARM=7)"; \
            CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=arm GOARM=7 \
            go build -tags "$BUILD_TAGS" -trimpath -ldflags "-w -s -buildid=" -o /final/mihomo .; \
        else \
            echo "Unknown ARM variant, defaulting to GOARM=7"; \
            CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=arm GOARM=7 \
            go build -tags "$BUILD_TAGS" -trimpath -ldflags "-w -s -buildid=" -o /final/mihomo .; \
        fi; \
    else \
        CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
        go build -tags "$BUILD_TAGS" -trimpath -ldflags "-w -s -buildid=" -o /final/mihomo .; \
    fi
    
FROM scratch AS export
COPY --from=package /final /
